{
  "data": {
    "n_samples": 5000,
    "attack_ratio": 0.05,
    "random_seed": 42,
    "test_split": 0.2,
    "features": {
      "HTTP2_SBI_request_rate": {
        "normal": {
          "mean": 180,
          "std": 60
        },
        "attack": {
          "mean": 340,
          "std": 90
        }
      },
      "PFCP_session_msg_density": {
        "normal": {
          "mean": 70,
          "std": 25
        },
        "attack": {
          "mean": 160,
          "std": 50
        }
      },
      "NGAP_auth_anomaly_score": {
        "normal": {
          "mean": 0.15,
          "std": 0.07
        },
        "attack": {
          "mean": 0.25,
          "std": 0.14
        }
      },
      "GTPU_tunnel_throughput_variance": {
        "normal": {
          "mean": 0.1,
          "std": 0.05
        },
        "attack": {
          "mean": 0.28,
          "std": 0.11
        }
      }
    }
