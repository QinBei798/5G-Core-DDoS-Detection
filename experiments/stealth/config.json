{
  "data": {
    "n_samples": 5000,
    "attack_ratio": 0.05,
    "random_seed": 42,
    "test_split": 0.2,
    "features": {
      "HTTP2_SBI_request_rate": {
        "normal": {
          "mean": 100,
          "std": 30
        },
        "attack": {
          "mean": 800,
          "std": 200
        }
      },
      "PFCP_session_msg_density": {
        "normal": {
          "mean": 50,
          "std": 15
        },
        "attack": {
          "mean": 400,
          "std": 120
        }
      },
      "NGAP_auth_anomaly_score": {
        "normal": {
          "mean": 0.05,
          "std": 0.03
        },
        "attack": {
          "mean": 0.25,
          "std": 0.2
        }
      },
      "GTPU_tunnel_throughput_variance": {
        "normal": {
          "mean": 0.02,
          "std": 0.015
        },
        "attack": {
          "mean": 0.55,
          "std": 0.22
        }
      }
    }
  },
  "models": {
    "random_forest": {
